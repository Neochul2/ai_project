   "source": [
    "# Analysis Server (FastAPI)\n",
    "### 필수 설치\n",
    "```bash\n",
    "# pip install fastapi uvicorn ollama openai python-multipart python-dotenv nest-asyncio\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import base64\n",
    "from fastapi import FastAPI, UploadFile, File, Form\n",
    "from fastapi.middleware.cors import CORSMiddleware\n",
    "from dotenv import load_dotenv\n",
    "import ollama\n",
    "from openai import OpenAI\n",
    "import uvicorn\n",
    "import nest_asyncio\n",
    "\n",
    "# 환경 변수 로드\n",
    "load_dotenv()\n",
    "\n",
    "useModel = os.getenv(\"USE_MODEL\", \"OLLAMA\")\n",
    "openaiApiKey = os.getenv(\"OPENAI_API_KEY\")\n",
    "ollamaModel = os.getenv(\"OLLAMA_MODEL\", \"gemma4:e2b\")\n",
    "\n",
    "app = FastAPI()\n",
    "\n",
    "app.add_middleware(\n",
    "    CORSMiddleware,\n",
    "    allow_origins=[\"*\"],\n",
    "    allow_credentials=True,\n",
    "    allow_methods=[\"*\"],\n",
    "    allow_headers=[\"*\"],\n",
    ")\n",
    "\n",
    "async def analyzeWithOllama(imageBytes: bytes, userQuestion: str):\n",
    "    \"\"\"로컬 Ollama 모델을 사용하여 분석\"\"\"\n",
    "    try:\n",
    "        response = ollama.generate(\n",
    "            model=ollamaModel,\n",
    "            prompt=userQuestion,\n",
    "            images=[imageBytes]\n",
    "        )\n",
    "        return response['response']\n",
    "    except Exception as e:\n",
    "        return f\"Ollama 에러: {str(e)}\"\n",
    "\n",
    "async def analyzeWithGpt(imageBytes: bytes, userQuestion: str):\n",
    "    \"\"\"OpenAI GPT-4o를 사용하여 분석\"\"\"\n",
    "    try:\n",
    "        client = OpenAI(api_key=openaiApiKey)\n",
    "        base64Image = base64.b64encode(imageBytes).decode('utf-8')\n",
    "        \n",
    "        response = client.chat.completions.create(\n",
    "            model=\"gpt-4o\",\n",
    "            messages=[\n",
    "                {\n",
    "                    \"role\": \"user\",\n",
    "                    \"content\": [\n",
    "                        {\"type\": \"text\", \"text\": userQuestion},\n",
    "                        {\"type\": \"image_url\", \"image_url\": {\"url\": f\"data:image/jpeg;base64,{base64Image}\"}}\n",
    "                    ],\n",
    "                }\n",
    "            ],\n",
    "            max_tokens=500,\n",
    "        )\n",
    "        return response.choices[0].message.content\n",
    "    except Exception as e:\n",
    "        return f\"GPT 에러: {str(e)}\"\n",
    "\n",
    "@app.post(\"/analyze\")\n",
    "async def analyzeImage(\n",
    "    file: UploadFile = File(...),    # Node.js에서 'file'로 보냄\n",
    "    question: str = Form(...)       # Node.js에서 'question'으로 보냄\n",
    "):\n",
    "    imageContent = await file.read()\n",
    "    \n",
    "    result = \"\"\n",
    "    if useModel == \"OLLAMA\":\n",
    "        result = await analyzeWithOllama(imageContent, question)\n",
    "    else:\n",
    "        result = await analyzeWithGpt(imageContent, question)\n",
    "        \n",
    "    # 프론트엔드가 기다리는 형식 (text, answer)으로 반환\n",
    "    return {\n",
    "        \"text\": f\"분석 모델: {useModel}\",\n",
    "        \"answer\": result\n",
    "    }\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    nest_asyncio.apply()\n",
    "    print(f\"서버 시작 중... 모델: {useModel}\")\n",
    "    uvicorn.run(app, host=\"0.0.0.0\", port=8000)\n"
   ]
  }\n",
 ],\n",
